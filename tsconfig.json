{
	"compilerOptions": {
		"resolveJsonModule": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"strictPropertyInitialization": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"],
		"declaration": true,
		"declarationMap": true,
		"composite": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["**/*.ts"],
	"exclude": ["docs/.vitepress/**", "test/**"]
}
