{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": ".",
		"types": ["jest"],
		"declaration": false,
		"declarationMap": false,
		"composite": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"moduleResolution": "bundler"
	},
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": []
}
